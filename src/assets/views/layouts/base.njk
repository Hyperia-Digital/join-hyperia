<!DOCTYPE html>
<html lang="{{ lang or 'en' }}" dir="{{ dir or 'ltr' }}">
  <head>
    <link rel="stylesheet" href="{{ '/assets/styles/styles.css' | url }}" />

    <link rel="icon" type="image/svg+xml" href="/assets/images/favicon.svg">

    {#- Page title, meta tags, and other head elements -#}
    {%- include "partials/meta.njk" -%}
  </head>
  <body>
    <a class="visually-hidden" href="#main">Skip to content</a>

    <header>
      {%- include "partials/logo.njk" -%}
      {%- include "partials/navigation.njk" -%}
    </header>

    {#- Main content -#}
    <main id="main" tabindex="-1" data-pagefind-body>
      {% if not homepage %}
        <header class="page-header">
          <h1>
            {#- Page Title -#}
            {{ title | safe }}
          </h1>
        </header>
      {% endif %}

      {#- Content from the page or post -#}
      {{ content | safe }}
    </main>

    {#- Site footer with copyright -#}
    {%- include "partials/site-footer.njk" -%}

    <script src="{{ '/assets/scripts/main.js' | url }}"></script>
  </body>
</html>
